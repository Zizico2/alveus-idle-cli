{
  "$schema": "../schemas/room.schema.json",
  "room_id": "pasture",
  "display_name": "The Pasture",
  "grid": {
    "width": 21,
    "height": 21,
    "tile_size_px": 32
  },
  "walls": {
    "style": "perimeter",
    "color": { "r": 0.35, "g": 0.30, "b": 0.20 },
    "excluded_tiles": [
      { "x": 10, "y": 0 }
    ]
  },
  "floor": {
    "style": "fill_interior",
    "color": { "r": 0.28, "g": 0.55, "b": 0.22 }
  },
  "door": {
    "position": { "x": 10, "y": 0 },
    "wall_side": "south",
    "width_tiles": 1,
    "color": { "r": 0.45, "g": 0.35, "b": 0.20 }
  },
  "spawn_point": { "x": 10, "y": 2 },
  "exit_target": { "x": 20, "y": 24 },
  "objects": [
    {
      "object_id": "stompy_shelter",
      "display_name": "Stompy's Shelter",
      "position": { "x": 4, "y": 17 },
      "size": { "w": 3, "h": 2 },
      "is_obstacle": true,
      "is_interactable": false,
      "color": { "r": 0.40, "g": 0.30, "b": 0.18 },
      "z_layer": 0.2
    },
    {
      "object_id": "emu_feed_bin",
      "display_name": "Emu Feed Bin",
      "position": { "x": 15, "y": 15 },
      "is_obstacle": true,
      "is_interactable": true,
      "interaction": {
        "type": "give_item",
        "item_id": "raw_veggie_tub",
        "prompt_text": "Grab a veggie tub from the feed bin"
      },
      "color": { "r": 0.50, "g": 0.40, "b": 0.20 },
      "z_layer": 0.2
    },
    {
      "object_id": "wooden_trough",
      "display_name": "Wooden Trough",
      "position": { "x": 10, "y": 10 },
      "size": { "w": 2, "h": 1 },
      "is_obstacle": true,
      "is_interactable": true,
      "interaction": {
        "type": "feed_animal",
        "target_animal_id": "stompy",
        "required_item_id": "prepared_veggie_diet",
        "stat_affected": "hunger",
        "stat_delta": 1.0,
        "prompt_text": "Dump prepared veggie diet into the trough"
      },
      "color": { "r": 0.55, "g": 0.40, "b": 0.15 },
      "z_layer": 0.2
    },
    {
      "object_id": "shiny_mirror_post",
      "display_name": "Shiny Mirror Post",
      "position": { "x": 18, "y": 8 },
      "is_obstacle": false,
      "is_interactable": true,
      "interaction": {
        "type": "enrich_animal",
        "target_animal_id": "stompy",
        "stat_affected": "happiness",
        "stat_delta": 1.0,
        "prompt_text": "Place a shiny object on the mirror post"
      },
      "color": { "r": 0.80, "g": 0.80, "b": 0.90 },
      "z_layer": 0.2
    },
    {
      "object_id": "water_spigot",
      "display_name": "Water Spigot",
      "position": { "x": 1, "y": 10 },
      "is_obstacle": true,
      "is_interactable": true,
      "interaction": {
        "type": "toggle_fixture",
        "stat_affected": "happiness",
        "stat_delta": 0.5,
        "prompt_text": "Turn on pasture sprinklers"
      },
      "color": { "r": 0.50, "g": 0.55, "b": 0.60 },
      "z_layer": 0.2
    }
  ],
  "animals": [
    {
      "animal_id": "stompy",
      "home_position": { "x": 10, "y": 14 },
      "wander_zone": {
        "bottom_left": { "x": 2, "y": 2 },
        "top_right": { "x": 19, "y": 19 }
      }
    }
  ],
  "zones": [],
  "dynamic_spawns": [
    {
      "spawn_id": "manure_piles",
      "object_template": "manure_pile",
      "count": { "min": 2, "max": 4 },
      "spawn_area": {
        "bottom_left": { "x": 2, "y": 2 },
        "top_right": { "x": 19, "y": 19 }
      },
      "interaction": {
        "type": "clean_tile",
        "target_animal_id": "stompy",
        "stat_affected": "cleanliness",
        "stat_delta": 0.34,
        "prompt_text": "Sweep manure pile"
      },
      "color": { "r": 0.40, "g": 0.28, "b": 0.12 }
    }
  ],
  "ambient": {
    "floor_color": { "r": 0.28, "g": 0.55, "b": 0.22 },
    "wall_color": { "r": 0.35, "g": 0.30, "b": 0.20 },
    "background_color": { "r": 0.12, "g": 0.20, "b": 0.10 }
  }
}
