{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alveus-idle-cli/schemas/event.schema.json",
  "title": "DailyEventDefinition",
  "description": "Defines a dynamic daily event that modifies normal gameplay during a session.",
  "type": "object",
  "required": ["event_id", "display_name", "weight", "affected_rooms", "modifications"],
  "additionalProperties": false,
  "properties": {
    "event_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "display_name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "weight": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Relative probability weight for this event. Higher = more common. Sum of all weights used for normalization."
    },
    "affected_rooms": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of room_ids affected by this event."
    },
    "modifications": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/EventModification"
      }
    },
    "visual_effects": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Visual effect identifiers to apply (e.g., 'rain_overlay', 'milky_eye_overlay')."
    },
    "rewards": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/EventReward"
      }
    }
  },
  "$defs": {
    "EventModification": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "disable_object",
            "replace_interaction",
            "add_extra_interactions",
            "spawn_npcs",
            "modify_chore_count"
          ]
        },
        "target_object_id": {
          "type": "string"
        },
        "replacement_interaction": {
          "type": "object",
          "description": "New interaction definition replacing the original."
        },
        "extra_count": {
          "type": "integer",
          "description": "For 'modify_chore_count': new required interaction count."
        },
        "npc_count": {
          "type": "integer",
          "description": "For 'spawn_npcs': number of helper NPCs."
        },
        "npc_chore_type": {
          "type": "string",
          "description": "For 'spawn_npcs': chore type the NPCs automatically complete."
        }
      }
    },
    "EventReward": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["item", "coins", "stamp"]
        },
        "item_id": { "type": "string" },
        "amount": { "type": "integer" }
      }
    }
  }
}
