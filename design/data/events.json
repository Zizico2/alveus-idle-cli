      "weight": 0.15,
      "affected_rooms": ["studio"],
      "modifications": [
        {
          "type": "disable_object",
          "target_object_id": "bug_jar_rack"
        },
        {
          "type": "replace_interaction",
          "target_object_id": "georgie_tank",
