      "weight": 0.15,
      "affected_rooms": ["studio"],
      "modifications": [
        {
          "type": "modify_chore_count",
          "target_object_id": "siren_enclosure",
          "extra_count": 3
        }
      ],
      "visual_effects": ["milky_eye_overlay", "dulled_skin"],
      "rewards": [
        {
          "type": "item",
          "item_id": "shed_snake_skin",
          "amount": 1
        }
      ]
    },
    {
      "event_id": "escaped_crickets",
