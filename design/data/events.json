{
  "$schema": "../schemas/event.schema.json",
  "events": [
    {
      "event_id": "rainy_day",
      "display_name": "The Rainy Day",
      "description": "Rain falls across the sanctuary. Stompy's trough is covered and sprinkler enrichment is disabled. Player must towel Stompy off inside his shelter instead.",
      "weight": 0.20,
      "affected_rooms": ["pasture"],
      "modifications": [
        {
          "type": "disable_object",
          "target_object_id": "water_spigot"
        },
        {
          "type": "replace_interaction",
          "target_object_id": "stompy_shelter",
          "replacement_interaction": {
            "type": "enrich_animal",
            "target_animal_id": "stompy",
            "stat_affected": "happiness",
            "stat_delta": 1.0,
            "prompt_text": "Towel off Stompy inside the shelter"
          }
        }
      ],
      "visual_effects": ["rain_overlay", "muddy_patches"],
      "rewards": []
    },
    {
      "event_id": "siren_shed_day",
      "display_name": "Siren's Shed Day",
