        "happiness": {
          "decay_rate_per_hour": 0.05,
          "initial_value": 1.0,
          "time_to_empty_hours": 20.0
        }
      },
      "care_requirements": {
        "feeding": {
          "description": "Fill Polly's feed bowl with chicken grains scooped from the Seed Chest in the Nutrition House.",
          "stat_restored": "hunger",
          "restore_amount": 1.0,
          "required_item_id": "chicken_grains",
          "interaction_object_id": "polly_feed_bowl",
          "chore_type": "instant"
        },
        "cleaning": {
          "description": "Sweep Polly's nesting area in the Nutrition House playpen. No item required.",
          "stat_restored": "cleanliness",
          "restore_amount": 1.0,
          "interaction_object_id": "polly_nesting_box",
          "chore_type": "instant"
        },
        "enrichment": {
          "description": "Place a mini-mirror at Polly's Enrichment Zone. Polly pecks at her reflection happily.",
          "stat_restored": "happiness",
          "restore_amount": 1.0,
          "interaction_object_id": "polly_enrichment_post",
          "chore_type": "instant"
        }
      },
      "sprite": {
        "asset_path": "images/animals/polly.png",
        "frame_size": { "w": 32, "h": 32 },
        "animations": {
          "idle": { "frames": [0, 1], "frame_duration_ms": 500, "looping": true },
          "eat": { "frames": [2, 3, 4, 3], "frame_duration_ms": 200, "looping": false },
          "happy": { "frames": [5, 6, 7, 6], "frame_duration_ms": 150, "looping": false },
          "sad": { "frames": [8], "frame_duration_ms": 1000, "looping": true }
        }
      },
      "fact_cards": [
        {
          "title": "Polly the Silkie",
          "body": "Silkie chickens are known for their fluffy, silk-like plumage. Unlike most chickens, their feathers lack barbicels, giving them a fur-like appearance. They are one of the most docile and friendly chicken breeds.",
          "source": "Alveus Sanctuary"
        },
        {
          "title": "Did You Know?",
          "body": "Silkie chickens have black skin and bones, blue earlobes, and five toes on each foot (most chickens have four). They originated in China over 2,000 years ago.",
          "source": "Alveus Sanctuary"
        }
      ],
      "enrichment_minigame": {
        "minigame_id": "mirror_cluckathon",
        "trigger_object_id": "polly_enrichment_post"
      }
    },
