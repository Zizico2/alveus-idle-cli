      "species": {
        "common_name": "Silkie Chicken",
        "scientific_name": "Gallus gallus domesticus",
        "category": "bird"
      },
      "stats": {
        "hunger": {
          "decay_rate_per_hour": 0.04,
          "initial_value": 1.0,
          "time_to_empty_hours": 25.0
