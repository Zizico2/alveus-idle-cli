{
  "$schema": "../schemas/economy.schema.json",
  "coin_generation": {
    "tiers": [
      {
        "name": "Excellent",
        "min_upkeep": 0.80,
        "coins_per_hour": 20
      },
      {
        "name": "Fair",
        "min_upkeep": 0.30,
        "coins_per_hour": 10
      },
      {
        "name": "Neglected",
        "min_upkeep": 0.00,
        "coins_per_hour": 0
      }
    ]
  },
  "upkeep_formula": {
    "description": "The Sanctuary Upkeep Score is the average of the mean hunger, mean cleanliness, and mean happiness across all active (unlocked) animals.",
    "formula": "(avg_hunger + avg_cleanliness + avg_happiness) / 3"
  },
  "neglect_freeze": {
    "threshold": 0.30,
    "effects": [
      "visual_desaturation: Palette shifts to somber gray-scale",
      "music_shift: Background music slows to minor-key piano/acoustic",
      "alert_banner: Persistent red banner at top of HUD with neglect warning",
      "animal_sad_emotes: Animals display sad scribble-like emotes above their heads",
      "coin_generation_halt: 0 coins/hour until stats recover above threshold"
    ]
  },
  "daily_bonus": {
    "coin_reward": 50,
    "condition": "All animal stats (hunger, cleanliness, happiness) at 100% when checking the HQ Clipboard."
  },
  "satchel": {
    "max_slots": 2
  },
